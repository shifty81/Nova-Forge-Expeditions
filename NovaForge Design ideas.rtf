\{\par
    std::cout << "[AI] Asset generator shutdown\\n";\par
\}\par
\par
EntityID AIAssetGenerator::GenerateAsset(const AIAssetRequest& request)\par
\{\par
    ECSEntityFactory::TransformInit t\{\};\par
    t.pos[0] = request.position[0];\par
    t.pos[1] = request.position[1];\par
    t.pos[2] = request.position[2];\par
\par
    t.rot[0] = request.rotation[0];\par
    t.rot[1] = request.rotation[1];\par
    t.rot[2] = request.rotation[2];\par
\par
    t.scale[0] = request.scale[0];\par
    t.scale[1] = request.scale[1];\par
    t.scale[2] = request.scale[2];\par
\par
    EntityID id = 0;\par
\par
    switch (request.category)\par
    \{\par
        case AssetCategory::Ship:\par
            id = ECSEntityFactory::CreateEntity(EntityType::Ship, t, "AI_Ship_Blank");\par
            ModuleAttachmentSystem::AttachDefaultModules(id);\par
            PhysicsIntegration::AddRigidBody(id, true);\par
            break;\par
\par
        case AssetCategory::Station:\par
            id = ECSEntityFactory::CreateEntity(EntityType::Station, t, "AI_Station_Blank");\par
            StationInteriorSystem::SpawnInterior(id);\par
            PhysicsIntegration::AddRigidBody(id, true);\par
            break;\par
\par
        case AssetCategory::Module:\par
        case AssetCategory::Prop:\par
            id = ECSEntityFactory::CreateEntity(EntityType::Module, t, "AI_Module_Blank");\par
            PhysicsIntegration::AddRigidBody(id, true);\par
            break;\par
\par
        case AssetCategory::NPC:\par
            id = ECSEntityFactory::CreateEntity(EntityType::Prop, t, "AI_NPC_Blank");\par
            PhysicsIntegration::AddRigidBody(id, false); // NPC dynamic\par
            break;\par
    \}\par
\par
    std::cout << "[AI] Generated asset id " << id << " category " << static_cast<int>(request.category) << "\\n";\par
\par
    return id;\par
\}\par
\par
std::vector<EntityID> AIAssetGenerator::GenerateBatch(const std::vector<AIAssetRequest>& requests)\par
\{\par
    std::vector<EntityID> result;\par
    for (const auto& req : requests)\par
    \{\par
        result.push_back(GenerateAsset(req));\par
    \}\par
    return result;\par
\}\par
