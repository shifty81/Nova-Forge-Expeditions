import random\par
from .module_defs import MODULE_SIZES\par
\par
def generate_slot_grid(seed, ship_class):\par
\par
    random.seed(seed)\par
\par
    grid = []\par
\par
    count = random.randint(4, 10)\par
\par
    sizes = list(MODULE_SIZES.keys())\par
\par
    for i in range(count):\par
\par
        size = random.choice(sizes)\par
\par
        grid.append(\{\par
            "size": size,\par
            "x": random.randint(-5,5),\par
            "y": random.randint(-5,5),\par
            "z": random.randint(-2,2),\par
        \})\par
\par
    return grid\par
