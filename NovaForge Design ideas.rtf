\f2 3\u-497?\f3\u8419?\f6  ENEMY BEHAVIOR TREES (LEAN & READABLE)\par
No black-box AI. These are data-driven trees.\par
\par
Enemy State Component\par
enum class EnemyCombatState \{\par
    IDLE,\par
    AWARE,\par
    ATTACKING,\par
    TAKING_COVER,\par
    RETREATING,\par
    DEAD\par
\};\par
\par
struct EnemyAIComponent \{\par
    EnemyCombatState state = EnemyCombatState::IDLE;\par
    float bravery;\par
    float health;\par
\};\par
Behavior Tree Logic (Core)\par
class EnemyAISystem \{\par
public:\par
    void Tick(Entity enemy, float dt) \{\par
        auto& ai = ecs.Get<EnemyAIComponent>(enemy);\par
\par
        if (ai.health <= 0.f) \{\par
            ai.state = EnemyCombatState::DEAD;\par
            return;\par
        \}\par
\par
        switch (ai.state) \{\par
            case EnemyCombatState::IDLE:\par
                if (CanSeePlayer(enemy))\par
                    ai.state = EnemyCombatState::AWARE;\par
                break;\par
\par
            case EnemyCombatState::AWARE:\par
                ai.state = EnemyCombatState::ATTACKING;\par
                break;\par
\par
            case EnemyCombatState::ATTACKING:\par
                if (UnderHeavyFire(enemy))\par
                    ai.state = EnemyCombatState::TAKING_COVER;\par
                else\par
                    FireAtPlayer(enemy);\par
                break;\par
\par
            case EnemyCombatState::TAKING_COVER:\par
                MoveToCover(enemy);\par
                if (ai.health < 30.f && ai.bravery < 0.5f)\par
                    ai.state = EnemyCombatState::RETREATING;\par
                else\par
                    ai.state = EnemyCombatState::ATTACKING;\par
                break;\par
\par
            case EnemyCombatState::RETREATING:\par
                FallBackTowardObjective(enemy);\par
                break;\par
        \}\par
    \}\par
\};\par
\f3\u10004?\f7  \f6 No teleporting\par
\f3\u10004?\f7  \f6 Player can read intent\par
\f3\u10004?\f7  \f6 Cheap CPU\par
