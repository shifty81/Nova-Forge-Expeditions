    float scale[3];               // optional\par
\};\par
\par
class AIAssetGenerator\par
\{\par
public:\par
    static AIAssetGenerator& Get();\par
\par
    void Initialize();\par
    void Shutdown();\par
\par
    // generate asset in world from request\par
    EntityID GenerateAsset(const AIAssetRequest& request);\par
\par
    // generate multiple assets\par
    std::vector<EntityID> GenerateBatch(const std::vector<AIAssetRequest>& requests);\par
\par
private:\par
