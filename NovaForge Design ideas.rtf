            id = ECSEntityFactory::CreateEntity(EntityType::Module, t, "AI_Module_Blank");\par
            PhysicsIntegration::AddRigidBody(id, true);\par
            break;\par
\par
        case AssetCategory::NPC:\par
            id = ECSEntityFactory::CreateEntity(EntityType::Prop, t, "AI_NPC_Blank");\par
