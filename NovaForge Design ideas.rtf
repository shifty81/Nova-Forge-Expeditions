\par
Core Types\par
enum class PlayerMode \{\par
    FPS,\par
    FLIGHT,\par
    FLEET_COMMAND\par
\};\par
Mode Interface (no cross-talk allowed)\par
class IPlayerMode \{\par
public:\par
    virtual ~IPlayerMode() = default;\par
\par
    virtual void OnEnter() = 0;\par
    virtual void OnExit() = 0;\par
    virtual void Tick(float dt) = 0;\par
\par
    // hard ownership\par
    virtual void BindInput() = 0;\par
    virtual void UnbindInput() = 0;\par
\par
    virtual void ActivateUI() = 0;\par
    virtual void DeactivateUI() = 0;\par
\par
    virtual void ActivateCamera() = 0;\par
    virtual void DeactivateCamera() = 0;\par
\};\par
PlayerModeController (this owns everything)\par
class PlayerModeController \{\par
public:\par
    void RegisterMode(PlayerMode mode, std::unique_ptr<IPlayerMode> impl);\par
    void RequestMode(PlayerMode target);\par
    void Tick(float dt);\par
\par
    PlayerMode GetCurrent() const \{ return current; \}\par
\par
private:\par
    PlayerMode current = PlayerMode::FPS;\par
    PlayerMode pending = PlayerMode::FPS;\par
\par
    std::unordered_map<PlayerMode, std::unique_ptr<IPlayerMode>> modes;\par
\par
    void Transition();\par
\};\par
Transition Logic (NO SHORTCUTS)\par
void PlayerModeController::RequestMode(PlayerMode target) \{\par
    if (target == current) return;\par
    pending = target;\par
\}\par
\par
void PlayerModeController::Tick(float dt) \{\par
    if (pending != current) \{\par
        Transition();\par
    \}\par
    modes[current]->Tick(dt);\par
\}\par
\par
void PlayerModeController::Transition() \{\par
    auto& from = modes[current];\par
    auto& to   = modes[pending];\par
\par
    from->UnbindInput();\par
    from->DeactivateUI();\par
    from->DeactivateCamera();\par
    from->OnExit();\par
\par
    // optional: fade / time-slow hook here\par
\par
    to->OnEnter();\par
    to->ActivateCamera();\par
    to->ActivateUI();\par
    to->BindInput();\par
\par
    current = pending;\par
\}\par
Rule:\par
If something feels wrong \f7\u8594? \f6 fix the transition, not the mode.\par
