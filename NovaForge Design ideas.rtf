\par
    return id;\par
\}\par
\par
std::vector<EntityID> AIAssetGenerator::GenerateBatch(const std::vector<AIAssetRequest>& requests)\par
\{\par
    std::vector<EntityID> result;\par
    for (const auto& req : requests)\par
    \{\par
        result.push_back(GenerateAsset(req));\par
    \}\par
    return result;\par
\}\par
