struct ICommand \{\par
    virtual ~ICommand() = default;\par
    virtual void Execute() = 0;\par
    virtual void Undo() = 0;  // optional for undo/redo\par
\};\par
\par
class EditorCommandBus \{\par
private:\par
    std::queue<std::unique_ptr<ICommand>> commandQueue;\par
    std::stack<std::unique_ptr<ICommand>> undoStack;\par
    std::stack<std::unique_ptr<ICommand>> redoStack;\par
\par
public:\par
    void PostCommand(std::unique_ptr<ICommand> cmd);\par
    void ProcessCommands();\par
    void UndoLast();\par
    void RedoLast();\par
\};\par
