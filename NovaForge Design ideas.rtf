\f5\u-10180?\u-8283?\f7  \f6 Breach Transition System\par
class BreachVisualSystem \{\par
public:\par
    void Trigger(Entity player) \{\par
        auto& bv = ecs.Get<BreachVisualComponent>(player);\par
        bv.phase = BreachVisualPhase::SHOCK;\par
        bv.timer = 0.f;\par
\par
        EventBus::Emit(CameraEvent\{"SHAKE_VIOLENT"\});\par
        EventBus::Emit(AudioEvent\{"HULL_BREACH"\});\par
        EventBus::Emit(ScreenFX\{"WHITE_FLASH"\});\par
    \}\par
\par
    void Tick(Entity player, float dt) \{\par
        auto& bv = ecs.Get<BreachVisualComponent>(player);\par
\par
        bv.timer += dt;\par
\par
        switch (bv.phase) \{\par
            case BreachVisualPhase::SHOCK:\par
                if (bv.timer > 0.6f) \{\par
                    bv.phase = BreachVisualPhase::SUCTION;\par
                    EventBus::Emit(ScreenFX\{"VIGNETTE_PULL"\});\par
                    EventBus::Emit(EnvironmentEvent\{"ZERO_G_ON"\});\par
                \}\par
                break;\par
\par
            case BreachVisualPhase::SUCTION:\par
                ApplyCameraDrift(player);\par
                if (bv.timer > 6.0f) \{\par
                    bv.phase = BreachVisualPhase::RECOVERY;\par
                    EventBus::Emit(AudioEvent\{"BULKHEAD_SEAL"\});\par
                    EventBus::Emit(EnvironmentEvent\{"ZERO_G_OFF"\});\par
                \}\par
                break;\par
\par
            case BreachVisualPhase::RECOVERY:\par
                FadeEffectsOut();\par
                if (bv.timer > 9.0f) \{\par
                    bv.phase = BreachVisualPhase::NONE;\par
                \}\par
                break;\par
        \}\par
    \}\par
\};\par
