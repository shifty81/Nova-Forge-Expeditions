2. Node & Connection Skeleton\par
struct BlueprintNode\par
\{\par
    std::string id;\par
    std::string type; // Event, Action, Condition\par
    std::unordered_map<std::string, std::string> parameters; // e.g., \{"TargetEntity":"Ship01"\}\par
    std::vector<std::string> outputNodeIds; // connected nodes\par
\};\par
\par
class BlueprintGraph\par
\{\par
public:\par
    std::unordered_map<std::string, BlueprintNode> nodes;\par
\par
    void AddNode(const BlueprintNode& node);\par
    void RemoveNode(const std::string& nodeId);\par
    void ConnectNodes(const std::string& fromNode, const std::string& toNode);\par
    void ExecuteNode(const std::string& nodeId); // runs logic recursively\par
\};\par
Each node has parameters and can connect to multiple outputs.\par
\par
Execution is depth-first, optional cycle detection to avoid infinite loops.\par
