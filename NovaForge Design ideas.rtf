struct TodoTask\par
\{\par
    std::string description;\par
    uint64_t targetEntity;\par
    bool completed = false;\par
\};\par
\par
struct TodoList\par
\{\par
    std::vector<TodoTask> tasks;\par
\par
    void AddTask(uint64_t entityId, const std::string& description)\par
    \{\par
        tasks.push_back(\{ description, entityId, false \});\par
    \}\par
\par
    void MarkComplete(uint64_t entityId, const std::string& description)\par
    \{\par
        for (auto& t : tasks)\par
        \{\par
            if (t.targetEntity == entityId && t.description == description)\par
            \{\par
                t.completed = true;\par
                break;\par
            \}\par
        \}\par
    \}\par
\par
    void RenderSign(); // Render floating 3D sign in room\par
\};\par
\par
struct Room\par
\{\par
    std::string name;\par
    int floorNumber;\par
    std::vector<uint64_t> entityIds;\par
    TodoList todoList;\par
\};\par
\par
class DevStation\par
\{\par
public:\par
    void Initialize();\par
    void LoadRooms();\par
    void LoadRoom(const std::string& roomName, int floorNumber, const std::vector<DeltaAsset>& assets);\par
    void SpawnElevator();\par
    void TeleportToFloor(int floorNumber);\par
    void RenderTodoSigns();\par
    Room* GetRoom(int floorNumber);\par
\par
private:\par
