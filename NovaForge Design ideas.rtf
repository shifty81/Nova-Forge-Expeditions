void DevWorld::Load()\par
\{\par
    // Clear existing world\par
    World::Clear();\par
\par
    // Load planets\par
    for (auto& p : DevAssets::planets)\par
        ECSEntityFactory::CreateEntity(EntityType::Planet, p.transform, p.blueprint);\par
\par
    // Load stations\par
    for (auto& s : DevAssets::stations)\par
        ECSEntityFactory::CreateEntity(EntityType::Station, s.transform, s.blueprint);\par
\par
    // Load ships\par
    for (auto& h : DevAssets::hulls)\par
    \{\par
        EntityID shipId = ECSEntityFactory::CreateEntity(EntityType::Ship, h.transform, h.blueprint);\par
        ModuleAttachmentSystem::AttachDefaultModules(shipId);\par
        PhysicsIntegration::AddRigidBody(shipId, true); // kinematic for editing\par
    \}\par
\par
    // Load props and NPCs\par
    for (auto& prop : DevAssets::props)\par
        ECSEntityFactory::CreateEntity(EntityType::Prop, prop.transform, prop.blueprint);\par
\par
    for (auto& npc : DevAssets::npcs)\par
        AICharacterGenerator::Get().SpawnCharacter(npc);\par
\par
    // Apply all saved deltas\par
    DeltaTracker::Get().ApplyAll();\par
\}\par
