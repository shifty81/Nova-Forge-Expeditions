Geometry Primitive (Flat-Shaded Box)\par
struct LowPolyMesh \{\par
    std::vector<Vec3> positions;\par
    std::vector<Vec3> normals;\par
    std::vector<uint32_t> indices;\par
\};\par
LowPolyMesh MakeFlatBox(Vec3 size) \{\par
    LowPolyMesh m;\par
\par
    // 6 faces, 4 verts each (no sharing!)\par
    for (Face f : BoxFaces(size)) \{\par
        Vec3 n = f.normal;\par
        for (Vec3 p : f.vertices) \{\par
            m.positions.push_back(p);\par
            m.normals.push_back(n);\par
        \}\par
        AppendQuadIndices(m.indices);\par
    \}\par
    return m;\par
\}\par
One-Mutation Rule\par
void ApplyMutation(LowPolyMesh& m) \{\par
    switch (RandomInt(0,2)) \{\par
        case 0: ScaleAxis(m, Axis::X, 0.8f); break;\par
        case 1: InsetFace(m, RandomFace(), 0.4f); break;\par
        case 2: RemoveFace(m, RandomFace()); break;\par
    \}\par
\}\par
\f2\u9888?\u-497?\f7  \f6 Never stack mutations. If one fails validation \f7\u8594? \f6 regenerate.\par
\par
FPS Layout Enforcement\par
bool ValidateFPSRoom(const RoomDesc& d) \{\par
    if (d.type == RoomType::COMBAT) \{\par
        return d.size.x >= 6 && d.size.z >= 6;\par
    \}\par
    return true;\par
\}\par
