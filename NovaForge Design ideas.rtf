    std::vector<HangarSlot> modularSlots;\par
    int hangarFloor = 0;\par
\};\par
2. Initialization & Dock Spawning\par
void XXLHangar::Initialize()\par
\{\par
    SpawnCentralDock();\par
    SpawnParallelDocks(4);        // e.g., 4 parallel medium docks\par
    SpawnModularGarages(24);      // surrounding fighter/escort slots\par
    ApplyDeltaEdits();\par
    PropagateStyleToFleet();\par
\}\par
\par
void XXLHangar::SpawnCentralDock()\par
\{\par
    centralDock.shipEntityId = ECSEntityFactory::CreateEntity("CapitalShip", \{/*transform*/\});\par
    centralDock.hangarType = "Capital";\par
    centralDock.occupied = true;\par
\}\par
\par
void XXLHangar::SpawnParallelDocks(int count)\par
\{\par
    parallelDocks.resize(count);\par
    for (int i = 0; i < count; ++i)\par
    \{\par
        parallelDocks[i].shipEntityId = ECSEntityFactory::CreateEntity("MediumShip", \{/*transform*/\});\par
        parallelDocks[i].hangarType = "Medium";\par
        parallelDocks[i].occupied = true;\par
    \}\par
\}\par
\par
void XXLHangar::SpawnModularGarages(int count)\par
\{\par
    modularSlots.resize(count);\par
    for (int i = 0; i < count; ++i)\par
    \{\par
        modularSlots[i].shipEntityId = 0; // empty slot\par
        modularSlots[i].hangarType = "Small";\par
        modularSlots[i].occupied = false;\par
    \}\par
\}\par
3. Pilot Assignment\par
void XXLHangar::AssignPilot(uint64_t shipId, const std::string& pilotId)\par
\{\par
    // Find slot for this ship\par
    for (auto& slot : slots)\par
    \{\par
        if (slot.shipEntityId == shipId)\par
        \{\par
            slot.occupied = true;\par
            // Assign pilot component in ECS\par
            ECSEntityFactory::AssignComponent(pilotId, "PilotComponent", shipId);\par
            break;\par
        \}\par
    \}\par
\}\par
Pilots can be assigned dynamically from the ToolingLayer overlay.\par
\par
Pilot assignment affects module access, ship control, and AI behavior.\par
\par
4. DeltaEdits Integration\par
void XXLHangar::ApplyDeltaEdits()\par
\{\par
    // Apply any existing DeltaEdits for each ship or module\par
    for (auto& slot : slots)\par
    \{\par
        if (slot.shipEntityId != 0)\par
        \{\par
            DeltaAsset delta = DeltaTracker::Get().ExtractDelta(slot.shipEntityId);\par
            DeltaTracker::Get().ApplyDelta(slot.shipEntityId, delta);\par
        \}\par
    \}\par
\}\par
Ensures all in-editor changes persist across sessions.\par
\par
Automatically updates PCGStyleCompiler templates for procedural hangar generation.\par
\par
5. PCG Style Propagation\par
void XXLHangar::PropagateStyleToFleet()\par
\{\par
    for (auto& slot : slots)\par
    \{\par
        if (slot.shipEntityId != 0)\par
        \{\par
            DeltaAsset delta = DeltaTracker::Get().ExtractDelta(slot.shipEntityId);\par
            HangarStyleTemplate styleTemplate;\par
            styleTemplate.type = slot.hangarType;\par
            styleTemplate.layoutEdits = delta;\par
            styleTemplate.inheritanceStrength = 1.0f;\par
\par
            PCGStyleCompiler::Get().PropagateHangarStyle(styleTemplate);\par
        \}\par
    \}\par
\}\par
Completed edits in one XXL hangar influence all other hangars of matching type and size.\par
\par
Scales modular garages as fleet size grows.\par
\par
Can also update parallel docks and central bay automatically.\par
\par
