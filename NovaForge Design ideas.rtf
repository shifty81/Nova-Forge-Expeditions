Room Descriptor (Input)\par
enum class RoomType \{\par
    ENTRY,\par
    COMBAT,\par
    SIDE,\par
    OBJECTIVE\par
\};\par
\par
struct RoomDesc \{\par
    RoomType type;\par
    Vec3 size;            // meters\par
    bool allowCover;\par
    bool allowElevation;\par
