Geometry Damage\par
void ApplyDamage(LowPolyMesh& m, const DamageEvent& d) \{\par
    for (Face& f : m.faces) \{\par
        if (Distance(f.center, d.position) < d.radius) \{\par
            if (Random() < d.severity) \{\par
                InsetFace(m, f, 0.2f * d.severity);\par
            \}\par
        \}\par
    \}\par
\}\par
Color Burn\par
void ApplyBurn(Room& r, const DamageEvent& d) \{\par
    for (Surface& s : r.surfaces) \{\par
        float dist = Distance(s.center, d.position);\par
        if (dist < d.radius) \{\par
            s.color = Lerp(s.color, Color::Black, 0.4f);\par
        \}\par
    \}\par
\}\par
