EntityID AIAssetGenerator::GenerateAsset(const AIAssetRequest& request)\par
\{\par
    ECSEntityFactory::TransformInit t\{\};\par
    t.pos[0] = request.position[0];\par
    t.pos[1] = request.position[1];\par
    t.pos[2] = request.position[2];\par
\par
    t.rot[0] = request.rotation[0];\par
    t.rot[1] = request.rotation[1];\par
    t.rot[2] = request.rotation[2];\par
\par
    t.scale[0] = request.scale[0];\par
    t.scale[1] = request.scale[1];\par
    t.scale[2] = request.scale[2];\par
\par
    EntityID id = 0;\par
\par
    switch (request.category)\par
    \{\par
        case AssetCategory::Ship:\par
            id = ECSEntityFactory::CreateEntity(EntityType::Ship, t, "AI_Ship_Blank");\par
            ModuleAttachmentSystem::AttachDefaultModules(id);\par
            PhysicsIntegration::AddRigidBody(id, true);\par
            break;\par
\par
        case AssetCategory::Station:\par
            id = ECSEntityFactory::CreateEntity(EntityType::Station, t, "AI_Station_Blank");\par
            StationInteriorSystem::SpawnInterior(id);\par
            PhysicsIntegration::AddRigidBody(id, true);\par
