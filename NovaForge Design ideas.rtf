4. GravitySystem.cpp\par
#include "GravitySystem.h"\par
#include "PhysicsIntegration.h"\par
#include <iostream>\par
#include <cmath>\par
\par
static GravityZone g_zones[2] = \{\par
    \{9.81f, \{0,0,0\}, 5000\}, // example station\par
    \{3.7f, \{10000,0,0\}, 7000\} // example planet\par
\};\par
\par
void GravitySystem::ApplyGravity(EntityID id, float dt, PlayerMode mode)\par
\{\par
    if (mode == PlayerMode::EVA || mode == PlayerMode::Flight)\par
        return; // no gravity\par
\par
    float pos[3], rot[3], scale[3];\par
    PhysicsIntegration::GetTransform(id, pos, rot, scale);\par
\par
    for (auto& z : g_zones)\par
    \{\par
        float dx = pos[0]-z.center[0];\par
        float dy = pos[1]-z.center[1];\par
        float dz = pos[2]-z.center[2];\par
        float dist = std::sqrt(dx*dx + dy*dy + dz*dz);\par
\par
        if (dist < z.radius)\par
        \{\par
            float accel = z.strength * dt;\par
            pos[1] -= accel; // simplistic downward\par
        \}\par
    \}\par
\par
    PhysicsIntegration::SetTransform(id, pos, rot, scale);\par
\}\par
