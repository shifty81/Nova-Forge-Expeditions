    // Apply DeltaEdits if they exist\par
    DeltaTracker::Get().ApplyAssetDelta(shipId, shipAsset);\par
\par
    // Add room to DevStation\par
    rooms.push_back(hangarRoom);\par
    floorMap[floorNumber] = &rooms.back();\par
\}\par
