\f2 1\u-497?\f3\u8419?\f6  FPS COMBAT STATE MACHINE \f7\emdash  \f6 CODE\par
This is authoritative, tick-driven, and event-fed.\par
\par
Player Combat State Component\par
enum class PlayerCombatState \{\par
    EXPLORING,\par
    ALERT,\par
    ENGAGED,\par
    WOUNDED,\par
    BREACHED,\par
    DOWNED\par
\};\par
\par
struct PlayerCombatStateComponent \{\par
    PlayerCombatState state = PlayerCombatState::EXPLORING;\par
    float suitHealth = 100.f;\par
    float shield = 100.f;\par
\};\par
Combat State Update System\par
class PlayerCombatStateSystem \{\par
public:\par
    void Tick(Entity player, float dt) \{\par
        auto& combat = ecs.Get<PlayerCombatStateComponent>(player);\par
\par
        switch (combat.state) \{\par
            case PlayerCombatState::EXPLORING:\par
                if (EnemyDetected(player))\par
                    Transition(player, PlayerCombatState::ALERT);\par
                break;\par
\par
            case PlayerCombatState::ALERT:\par
                if (PlayerFired(player) || TookDamage(player))\par
                    Transition(player, PlayerCombatState::ENGAGED);\par
                break;\par
\par
            case PlayerCombatState::ENGAGED:\par
                if (combat.suitHealth < 40.f)\par
                    Transition(player, PlayerCombatState::WOUNDED);\par
                if (NoEnemiesNearby())\par
                    Transition(player, PlayerCombatState::EXPLORING);\par
                break;\par
\par
            case PlayerCombatState::WOUNDED:\par
                ApplyMovementPenalty(player);\par
                if (combat.suitHealth <= 0.f)\par
                    Transition(player, PlayerCombatState::DOWNED);\par
                break;\par
\par
            case PlayerCombatState::BREACHED:\par
                ApplyZeroGModifiers(player);\par
                break;\par
\par
            case PlayerCombatState::DOWNED:\par
                DisableInput(player);\par
                break;\par
        \}\par
    \}\par
\par
private:\par
    void Transition(Entity player, PlayerCombatState next) \{\par
        auto& combat = ecs.Get<PlayerCombatStateComponent>(player);\par
        combat.state = next;\par
        EventBus::Emit(PlayerCombatStateChanged\{player, next\});\par
    \}\par
\};\par
\f3\u10004?\f7  \f6 Centralized\par
\f3\u10004?\f7  \f6 Debuggable\par
\f3\u10004?\f7  \f6 Deterministic\par
\par
\f2 2\u-497?\f3\u8419?\f6  HULL BREACH \f7\emdash  \f6 REUSABLE EVENT SYSTEM\par
This is not scripted garbage \f7\emdash  \f6 it\f7\rquote\f6 s a reusable environmental event.\par
\par
Hull Breach Event Definition\par
struct HullBreachEvent \{\par
    Entity room;\par
    float forceStrength;\par
    float duration;\par
\};\par
Hull Breach System\par
class HullBreachSystem \{\par
public:\par
    void Trigger(const HullBreachEvent& event) \{\par
        breachedRoom = event.room;\par
        force = event.forceStrength;\par
        timer = event.duration;\par
\par
        EventBus::Emit(AudioEvent\{"HULL_BREACH"\});\par
        EventBus::Emit(EnvironmentEvent\{"ZERO_G_ON"\});\par
        EventBus::Emit(CameraEvent\{"SHAKE_HEAVY"\});\par
    \}\par
\par
    void Tick(float dt) \{\par
        if (timer <= 0.f) return;\par
\par
        timer -= dt;\par
\par
        ApplySuctionForces();\par
        PullLooseObjects();\par
\par
        if (timer <= 0.f)\par
            Resolve();\par
    \}\par
\par
private:\par
    Entity breachedRoom;\par
    float force;\par
    float timer;\par
\par
    void ApplySuctionForces() \{\par
        for (Entity e : ecs.Query<PhysicsComponent>(breachedRoom)) \{\par
            ecs.Get<PhysicsComponent>(e).velocity +=\par
                BreachNormal * force;\par
        \}\par
    \}\par
\par
    void Resolve() \{\par
        EventBus::Emit(EnvironmentEvent\{"ZERO_G_OFF"\});\par
        EventBus::Emit(AudioEvent\{"EMERGENCY_ALARM_STOP"\});\par
    \}\par
\};\par
Reusable anywhere:\par
\par
Weapons fire\par
\par
Reactor meltdown\par
\par
Scripted mission beats\par
