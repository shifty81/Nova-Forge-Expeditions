2. HangarStyleTemplate\par
struct HangarStyleTemplate\par
\{\par
    std::string type; // Small, Medium, Large, XXL\par
    DeltaEdits layoutEdits; // Transform/attachment deltas from completed hangar\par
    std::vector<uint64_t> assetCategories; // e.g., ships, props, NPCs\par
    float inheritanceStrength = 1.0f; // Weight of influence on PCG\par
\};\par
