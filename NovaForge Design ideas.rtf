\f2\u-10178?\u-8736?\f7  \f6 Director Logic\par
class EnemySpawnDirectorSystem \{\par
public:\par
    void Tick(float dt) \{\par
        director.threatBudget += director.regenRate * dt;\par
        director.threatBudget = std::min(director.threatBudget, 4.0f);\par
\par
        if (director.threatBudget >= 1.0f && CanSpawn()) \{\par
            SpawnEnemy();\par
        \}\par
    \}\par
\par
private:\par
    SpawnDirector director;\par
\par
    void SpawnEnemy() \{\par
        if (director.threatBudget >= 2.0f && PlayerDominating()) \{\par
            Spawn("BREACHER");\par
            director.threatBudget -= 2.0f;\par
        \} else \{\par
            Spawn("GRUNT");\par
            director.threatBudget -= 1.0f;\par
        \}\par
    \}\par
\};\par
