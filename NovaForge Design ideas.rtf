2. HangarStyleTemplate\par
struct HangarStyleTemplate\par
\{\par
    std::string type; // Small, Medium, Large, XXL\par
    DeltaEdits layoutEdits; // Transform/attachment deltas from completed hangar\par
    std::vector<uint64_t> assetCategories; // e.g., ships, props, NPCs\par
    float inheritanceStrength = 1.0f; // Weight of influence on PCG\par
\};\par
DeltaEdits stores positional, rotational, and module attachment changes.\par
\par
inheritanceStrength controls how strongly this completed hangar influences future PCG.\par
\par
3. Style Propagation Algorithm\par
void PCGStyleCompiler::PropagateHangarStyle(const HangarStyleTemplate& template)\par
\{\par
    // Get all hangars of same type\par
    auto hangars = DevWorld::Get().GetAllHangars(template.type);\par
\par
    for (auto& hangar : hangars)\par
    \{\par
        for (auto& entityId : hangar->entityIds)\par
        \{\par
            DeltaEdits deltas = template.layoutEdits;\par
            deltas.ScaleBy(hangar->ScaleFactor()); // Adjust for hangar size\par
            DeltaTracker::Get().ApplyDelta(entityId, deltas);\par
        \}\par
    \}\par
\}\par
All other hangars inherit style changes, scaled to their size.\par
