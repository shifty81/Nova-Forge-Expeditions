#include "DevWorldUpdateLoop.h"\par
\par
DevWorldUpdateLoop::DevWorldUpdateLoop(PlayerControllerBase* player,\par
                                       DevStation* station,\par
                                       ToolingLayer* tooling,\par
                                       DeltaTracker* delta,\par
                                       PCGPreview* preview,\par
                                       PCGStyleCompiler* compiler,\par
                                       BlueprintGraph* blueprint)\par
    : playerController(player),\par
      devStation(station),\par
      toolingLayer(tooling),\par
      deltaTracker(delta),\par
      pcgPreview(preview),\par
      pcgCompiler(compiler),\par
      blueprintGraph(blueprint)\par
\{\par
\}\par
\par
void DevWorldUpdateLoop::Tick(float deltaTime)\par
\{\par
    // 1. Player input and movement\par
    ProcessPlayerInput(deltaTime);\par
\par
    // 2. Apply all DeltaEdits from live editing\par
    ApplyDeltaEdits();\par
\par
    // 3. Update room/hangar todo lists\par
    UpdateTodoLists();\par
\par
    // 4. Refresh PCG preview for live scene\par
    RefreshPCGPreview();\par
\par
    // 5. Execute Blueprint nodes for triggered events\par
    ExecuteBlueprintNodes();\par
\}\par
\par
void DevWorldUpdateLoop::ProcessPlayerInput(float deltaTime)\par
\{\par
    // Updates FPS/EVA/Ship movement and interacts with entities\par
    if(playerController)\par
        playerController->Update(deltaTime);\par
\}\par
\par
void DevWorldUpdateLoop::ApplyDeltaEdits()\par
\{\par
    // Apply DeltaEdits to all rooms, hangars, ships, planets\par
    if(devStation)\par
        devStation->ApplyDeltaEdits();\par
\par
    // Record edits if ToolingLayer is active\par
    if(toolingLayer && toolingLayer->IsOverlayActive())\par
        deltaTracker->CommitFrameEdits();\par
\}\par
\par
void DevWorldUpdateLoop::UpdateTodoLists()\par
\{\par
    for(auto& room : devStation->rooms)\par
        room->todoList.CheckCompletion();\par
\par
    for(auto& hangar : devStation->hangars)\par
        hangar->todoList.CheckCompletion();\par
\}\par
\par
void DevWorldUpdateLoop::RefreshPCGPreview()\par
\{\par
    if(pcgPreview)\par
        pcgPreview->UpdateScene();\par
\}\par
\par
void DevWorldUpdateLoop::ExecuteBlueprintNodes()\par
\{\par
    if(blueprintGraph)\par
        blueprintGraph->Execute();\par
\}\par
Loop Workflow Explanation\par
Each tick performs the following step-by-step:\par
\par
ProcessPlayerInput\par
\par
FPS / EVA / Ship modes update positions and interactions.\par
\par
Input also controls ToolingLayer gizmos if overlay is active.\par
\par
ApplyDeltaEdits\par
\par
DeltaTracker captures live edits made by the player (moving modules, changing ship interiors, editing planets, spawning NPCs).\par
\par
DevStation propagates edits to hangars, fleet slots, and rooms.\par
\par
UpdateTodoLists\par
\par
Checks task completion per room/hangar.\par
\par
Completed tasks trigger style propagation via PCGStyleCompiler.\par
\par
RefreshPCGPreview\par
\par
Rebuilds mesh layouts, procedural placements, and any visual updates from DeltaEdits.\par
\par
Allows instant feedback for the player/editor.\par
\par
ExecuteBlueprintNodes\par
\par
Triggers connected actions (spawn NPCs, attach modules, trigger animation fixes, generate new ships).\par
\par
Blueprint nodes react dynamically to player actions or room completion.\par
\par
\f3\u9989?\f7  \f6 Benefits of this structure\par
\par
All edits are live and immediately visible.\par
\par
DeltaEdits feed PCG style, so DevWorld updates propagate globally.\par
\par
Blueprints provide dynamic procedural and interactive behavior.\par
\par
Hangars, rooms, fleet slots, planets, ships, and NPCs are fully integrated in one editable scene.\par
\par
Player can switch modes (FPS/EVA/Ship) seamlessly while editing.\par
