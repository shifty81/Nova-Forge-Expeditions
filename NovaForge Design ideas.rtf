4. Blueprint Execution Example\par
void BlueprintGraph::ExecuteNode(const std::string& nodeId)\par
\{\par
    auto it = nodes.find(nodeId);\par
    if (it == nodes.end()) return;\par
\par
    BlueprintNode& node = it->second;\par
\par
    if (node.type == "Event")\par
    \{\par
        // Events may be triggered by ToolingLayer overlay\par
    \}\par
    else if (node.type == "Action")\par
    \{\par
        if (node.parameters["ActionType"] == "SpawnNPC")\par
        \{\par
            AIAssetRequest request;\par
            request.prompt = node.parameters["NPCType"];\par
            request.position[0] = std::stof(node.parameters["PosX"]);\par
            request.position[1] = std::stof(node.parameters["PosY"]);\par
            request.position[2] = std::stof(node.parameters["PosZ"]);\par
            \par
            Room* room = DevStation::Get().GetRoom(std::stoi(node.parameters["Floor"]));\par
            AIAssetSpawner::Get().SpawnInRoom(request, *room);\par
        \}\par
        else if (node.parameters["ActionType"] == "RegeneratePCG")\par
        \{\par
            PCGPreview::Get().RefreshScene();\par
        \}\par
        // add more ActionType handlers as needed\par
    \}\par
    else if (node.type == "Condition")\par
    \{\par
        if (node.parameters["ConditionType"] == "TaskCompleted")\par
        \{\par
            Room* room = DevStation::Get().GetRoom(std::stoi(node.parameters["Floor"]));\par
            bool complete = room->todoList.AllTasksCompleted();\par
            if (!complete) return; // stop execution\par
        \}\par
    \}\par
\par
    // Execute connected nodes recursively\par
    for (auto& outId : node.outputNodeIds)\par
        ExecuteNode(outId);\par
\}\par
