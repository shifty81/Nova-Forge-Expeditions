2. Room Loading & Kitbash Placement\par
void DevStation::LoadRoom(const std::string& roomName, int floorNumber, const std::vector<DeltaAsset>& assets)\par
\{\par
    Room newRoom;\par
    newRoom.name = roomName;\par
    newRoom.floorNumber = floorNumber;\par
\par
    for (const auto& asset : assets)\par
    \{\par
        uint64_t entityId = ECSEntityFactory::CreateEntity(asset.blueprint, asset.transform);\par
        newRoom.entityIds.push_back(entityId);\par
\par
        // Add tasks for editing\par
        newRoom.todoList.AddTask(entityId, "Edit Transform");\par
        if (asset.animationEditable)\par
            newRoom.todoList.AddTask(entityId, "Edit Animation");\par
        if (asset.category.find("Ship") != std::string::npos)\par
            newRoom.todoList.AddTask(entityId, "Attach Modules");\par
\par
        // Apply DeltaEdits if any\par
        DeltaTracker::Get().ApplyAssetDelta(entityId, asset);\par
    \}\par
\par
    rooms.push_back(newRoom);\par
    floorMap[floorNumber] = &rooms.back();\par
\}\par
