import bpy\par
import random\par
from .slot_grid import generate_slot_grid\par
\par
\par
def create_module(x, y, z, size):\par
\par
    bpy.ops.mesh.primitive_cube_add(\par
        size=size,\par
        location=(x, y, z),\par
    )\par
\par
\par
def generate_ship(seed, ship_class):\par
\par
    grid = generate_slot_grid(seed, ship_class)\par
\par
    for slot in grid:\par
\par
        create_module(\par
            slot["x"],\par
            slot["y"],\par
            slot["z"],\par
            1 + len(slot["size"])\par
        )\par
\par
