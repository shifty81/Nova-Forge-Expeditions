PlayerControllerBase::PlayerControllerBase()\par
\{\par
    fpsController  = new FPSController();\par
    evaController  = new EVAController();\par
    shipController = new ShipController();\par
\par
    // Pass deltaTracker to sub-controllers\par
    fpsController->SetDeltaTracker(deltaTracker);\par
    evaController->SetDeltaTracker(deltaTracker);\par
    shipController->SetDeltaTracker(deltaTracker);\par
\par
    currentMode = PlayerMode::FPS;\par
\}\par
\par
void PlayerControllerBase::SetMode(PlayerMode mode)\par
\{\par
    currentMode = mode;\par
    // ToolingLayer may react to mode switch if overlay active\par
    if(toolingLayer && toolingLayer->IsOverlayActive())\par
        toolingLayer->OnModeChanged(mode);\par
\}\par
\par
PlayerMode PlayerControllerBase::GetMode() const\par
\{\par
    return currentMode;\par
\}\par
\par
void PlayerControllerBase::Update(float deltaTime)\par
\{\par
    switch(currentMode)\par
    \{\par
        case PlayerMode::FPS:\par
            fpsController->Update(deltaTime);\par
            break;\par
        case PlayerMode::EVA:\par
            evaController->Update(deltaTime);\par
            break;\par
        case PlayerMode::Ship:\par
            shipController->Update(deltaTime);\par
            break;\par
    \}\par
\par
    // Optional: Blueprint nodes execute actions per tick\par
    if(blueprintGraph)\par
        blueprintGraph->Execute();\par
\}\par
